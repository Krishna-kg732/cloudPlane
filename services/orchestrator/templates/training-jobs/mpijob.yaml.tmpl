# MPIJob Template
# For Horovod, DeepSpeed, or custom MPI-based training

apiVersion: kubeflow.org/v1
kind: MPIJob
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  labels:
    app: cloudplane-training
    job-id: {{ .JobID }}
    framework: mpi
spec:
  slotsPerWorker: {{ .GPUsPerWorker }}
  runPolicy:
    cleanPodPolicy: Running
  mpiReplicaSpecs:
    Launcher:
      replicas: 1
      template:
        spec:
          containers:
            - name: mpi-launcher
              image: {{ .Image }}
              {{- if .Command }}
              command: {{ .Command | toJson }}
              {{- end }}
              {{- if .Args }}
              args: {{ .Args | toJson }}
              {{- end }}
              env:
                - name: OMPI_MCA_btl
                  value: "^openib"
                {{- if .EFAEnabled }}
                - name: FI_PROVIDER
                  value: "efa"
                - name: FI_EFA_USE_DEVICE_RDMA
                  value: "1"
                {{- end }}
              volumeMounts:
                - name: training-data
                  mountPath: /data
          volumes:
            - name: training-data
              persistentVolumeClaim:
                claimName: fsx-pvc
    Worker:
      replicas: {{ .Workers }}
      template:
        metadata:
          {{- if .EFAEnabled }}
          annotations:
            vpc.amazonaws.com/efa: "true"
          {{- end }}
        spec:
          tolerations:
            - key: "nvidia.com/gpu"
              operator: "Exists"
              effect: "NoSchedule"
          containers:
            - name: mpi-worker
              image: {{ .Image }}
              env:
                - name: NCCL_DEBUG
                  value: "INFO"
                {{- if .EFAEnabled }}
                - name: FI_PROVIDER
                  value: "efa"
                - name: FI_EFA_USE_DEVICE_RDMA
                  value: "1"
                - name: NCCL_NET
                  value: "ib"
                {{- end }}
              resources:
                limits:
                  nvidia.com/gpu: {{ .GPUsPerWorker }}
                  {{- if .EFAEnabled }}
                  vpc.amazonaws.com/efa: 4
                  {{- end }}
              volumeMounts:
                - name: training-data
                  mountPath: /data
                - name: checkpoints
                  mountPath: /checkpoints
                - name: shm
                  mountPath: /dev/shm
          volumes:
            - name: training-data
              persistentVolumeClaim:
                claimName: fsx-pvc
            - name: checkpoints
              persistentVolumeClaim:
                claimName: fsx-pvc
            - name: shm
              emptyDir:
                medium: Memory
                sizeLimit: 32Gi
